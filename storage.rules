
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Kural: Kullanıcılar yalnızca kendi kimlikleriyle (UID) eşleşen klasörlere yazabilir.
    // Bu, bir kullanıcının başka bir kullanıcının dosyalarını okumasını veya üzerine yazmasını engeller.
    match /uploads/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
