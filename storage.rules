
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Öğretmen ve öğrencilerin kendi ödev/dosya yüklemeleri için
    // kendi kullanıcı ID'leri altındaki klasörlere yazma izni.
    // Okuma izni de sadece kendilerine verilir.
    match /uploads/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
