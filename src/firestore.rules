
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- YARDIMCI FONKSİYONLAR ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function isTeacher() {
      return exists(/databases/$(database)/documents/teachers/$(request.auth.uid));
    }
    
    // Sınıfın sahibi olan öğretmen mi? (Tekil okuma/yazma için)
    function isClassOwner(classId) {
      return isTeacher() && get(/databases/$(database)/documents/classes/$(classId)).data.teacherId == request.auth.uid;
    }
    
    // --- ÖĞRENCİ GİRİŞ SORGUSU İÇİN KURAL ---
    // Bu kural, kimliği doğrulanmamış bir kullanıcının, sınıf kodu ve okul numarasına göre
    // SADECE 'students' koleksiyonunda arama yapmasına izin verir. Bu, güvenli ve verimlidir.
    match /students/{studentId} {
        allow list: if !isSignedIn(); // Sadece giriş yapmamışlar sorgulayabilir.
        
        // Giriş yapmış öğrenci kendi verisini okuyabilir/güncelleyebilir
        allow get, update: if isOwner(studentId);
        // Öğretmenler tüm öğrencileri okuyabilir/yazabilir
        allow read, write: if isTeacher();
    }
    
    // --- ÖĞRETMEN YÖNETİMİ ---
    match /teachers/{teacherId} {
      allow read: if isSignedIn();
      allow write: if isOwner(teacherId);
    }
    
    // --- SINIF KURALLARI ---
    match /classes/{classId} {
      // ÖĞRETMENLER: Kendi sınıflarını listeleyebilir, okuyabilir, yazabilir.
      allow list: if isTeacher() && request.query.where.field == "teacherId" && request.query.where.value == request.auth.uid;
      allow read, write: if isClassOwner(classId);

      // ÖĞRENCİLER: Sadece kendi sınıflarını okuyabilirler.
      allow get: if get(/databases/$(database)/documents/students/$(request.auth.uid)).data.classId == classId;
      
      // SINIF İÇİ ALT KOLEKSİYONLAR
      match /homeworks/{homeworkId} {
        allow read: if get(/databases/$(database)/documents/students/$(request.auth.uid)).data.classId == classId || isClassOwner(classId);
        allow write: if isClassOwner(classId);

        match /submissions/{submissionId} {
            allow read: if isClassOwner(classId);
            allow create: if isOwner(request.resource.data.studentId);
            allow get, update: if isOwner(resource.data.studentId);
        }
      }
    }
    
    // --- DİĞER GENEL KOLEKSİYONLAR ---
    match /infoForms/{formId} {
      allow get, update, create: if isOwner(formId);
      allow read: if isTeacher();
    }
    
    match /riskFactors/{riskFactorId} {
      allow read: if isSignedIn();
      allow write: if isTeacher();
    }

    match /lessons/{lessonId} {
      allow read: if isSignedIn();
      allow write: if isTeacher();
    }
    
    match /messages/{messageId} {
      allow read, write: if isSignedIn() && request.auth.uid in resource.data.participants;
    }
    
     match /surveys/{surveyId} {
        allow read: if isSignedIn();
        allow write: if isTeacher();
    }
    
    match /surveyResponses/{responseId} {
        allow create: if isSignedIn();
        allow read, list: if isTeacher();
    }
  }
}
