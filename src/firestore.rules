
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isTeacher(userId) {
      return exists(/databases/$(database)/documents/teachers/$(userId));
    }
    
    match /publicViews/{viewId} {
        allow get: if true;
        allow write: if request.auth != null &&
                      isTeacher(request.auth.uid) &&
                      exists(/databases/$(database)/documents/classes/$(viewId)) &&
                      get(/databases/$(database)/documents/classes/$(viewId)).data.teacherId == request.auth.uid;
    }

    match /classCodes/{code} {
        allow get: if true;
        allow write: if request.auth != null && isTeacher(request.auth.uid);
    }
    
    match /classes/{classId} {
        allow get: if true;
        allow write: if request.auth != null && isTeacher(request.auth.uid) && request.resource.data.teacherId == request.auth.uid;
    }
    
    match /students/{studentId} {
        allow get: if true;
        allow write: if request.auth != null && isTeacher(request.auth.uid);
    }

    match /messages/{messageId} {
      allow get: if request.auth != null && request.auth.uid in resource.data.participants;
      allow list: if request.auth != null && request.query.where['participants']['array-contains'] == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.senderId == request.auth.uid;
      allow update: if request.auth != null && resource.data.receiverId == request.auth.uid;
      allow delete: if false;
    }
    
    match /{document=**} {
      allow read, write: if request.path[0] != 'publicViews' && 
                           request.path[0] != 'classCodes' &&
                           request.path[0] != 'classes' &&
                           request.path[0] != 'students' &&
                           request.path[0] != 'messages' &&
                           true;
    }
  }
}
