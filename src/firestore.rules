
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isTeacher(userId) {
      return exists(/databases/$(database)/documents/teachers/$(userId));
    }
    
    // This collection is for public-facing, read-only views of data.
    match /publicViews/{viewId} {
        // Anyone can read a published view
        allow get: if true;
        
        // Only an authenticated teacher who owns the corresponding class can write here.
        // The viewId must match the classId.
        allow write: if request.auth != null &&
                      isTeacher(request.auth.uid) &&
                      exists(/databases/$(database)/documents/classes/$(viewId)) &&
                      get(/databases/$(database)/documents/classes/$(viewId)).data.teacherId == request.auth.uid;
    }

    match /classCodes/{code} {
        allow get: if true;
        allow write: if request.auth != null && isTeacher(request.auth.uid);
    }
    
    match /classes/{classId} {
        allow get: if true; // Allow students to read class data
        allow write: if request.auth != null && isTeacher(request.auth.uid) && request.resource.data.teacherId == request.auth.uid;
    }
    
    match /students/{studentId} {
        allow get: if true;
        allow write: if request.auth != null && isTeacher(request.auth.uid);
    }

    match /messages/{messageId} {
        allow read, write: if request.auth != null && (request.resource.data.senderId == request.auth.uid || request.resource.data.receiverId == request.auth.uid);
    }
    
    // Default open access for all other documents as per previous state
    // We add conditions to NOT match our new secure collections.
    match /{document=**} {
      allow read, write: if request.path[0] != 'publicViews' && 
                           request.path[0] != 'classCodes' &&
                           request.path[0] != 'classes' &&
                           request.path[0] != 'students' &&
                           request.path[0] != 'messages' &&
                           true;
    }
  }
}
