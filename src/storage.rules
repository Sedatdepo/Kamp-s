
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Genel kural: Varsayılan olarak tüm yollara erişimi engelle.
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // Ödev teslim dosyaları için kurallar
    // Yol: /homework_submissions/{classId}/{homeworkId}/{studentId}/{fileName}
    match /homework_submissions/{classId}/{homeworkId}/{studentId}/{fileName} {
      
      // OKUMA (GET): Öğretmenler tüm ödevleri okuyabilir.
      // Öğrenciler sadece kendi teslim ettikleri dosyaları okuyabilir.
      allow get: if request.auth != null && (
                    exists(/databases/$(database)/documents/teachers/$(request.auth.uid)) ||
                    request.auth.uid == get(/databases/$(database)/documents/students/$(studentId)).data.authUid
                  );

      // YAZMA (CREATE):
      // Yükleme isteği yapan kullanıcının kimliği (request.auth.uid),
      // dosya metadata'sına eklenen 'studentAuthUid' ile eşleşmelidir.
      // Bu, sadece doğru öğrencinin dosya yükleyebilmesini sağlar.
      allow create: if request.auth != null && 
                     request.auth.uid == request.resource.metadata.studentAuthUid;
                     
      allow update, delete: if false;
    }

    // Sohbet dosyaları için kurallar
    // Yol: /chat_files/{teacherId}/{studentId}/{fileName}
    match /chat_files/{teacherId}/{studentId}/{fileName} {
        
      // OKUMA ve YAZMA: Sadece sohbete dahil olan öğretmen veya öğrenci işlem yapabilir.
      // Yükleme için metadata kontrolü ekleyerek güvenliği artır.
      allow read: if request.auth != null && (
                       request.auth.uid == teacherId ||
                       request.auth.uid == get(/databases/$(database)/documents/students/$(studentId)).data.authUid
                     );
      allow write: if request.auth != null &&
                      request.auth.uid == request.resource.metadata.studentAuthUid;
    }
  }
}
