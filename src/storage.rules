
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow read access to all users for exam images
    match /exam_images/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Default to deny all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
