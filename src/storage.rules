rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Genel kural: Varsayılan olarak tüm yollara erişimi engelle.
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // Sunucu tarafından yüklenen ödev dosyaları için kurallar
    // Yol: /homework_submissions/{classId}/{homeworkId}/{studentId}/{fileName}
    match /homework_submissions/{classId}/{homeworkId}/{studentId}/{fileName} {
      
      // OKUMA (GET): Öğretmenler tüm ödevleri okuyabilir.
      // Öğrenciler sadece kendi teslim ettikleri dosyaları okuyabilir.
      // Not: Basit giriş sistemiyle öğrencinin 'auth' nesnesi olmaz. Bu kural öğretmene odaklanır.
      allow get: if request.auth != null && exists(/databases/$(database)/documents/teachers/$(request.auth.uid));

      // YAZMA (WRITE): İstemcilerden (tarayıcılardan) doğrudan yazmaya izin verilmez.
      // Tüm yüklemeler, yönetici yetkilerine sahip sunucu API rotası tarafından yapılacaktır.
      allow write: if false;
    }

    // Sohbet dosyaları için kurallar
    // Yol: /chat_files/{teacherId}/{studentId}/{fileName}
    match /chat_files/{teacherId}/{studentId}/{fileName} {
      // OKUMA: Sadece sohbete dahil olan öğretmen okuyabilir.
      // Öğrenci tarafı okuması, uygulama içinden link ile yapılır.
      allow read: if request.auth != null && request.auth.uid == teacherId;
      
      // YAZMA: Sadece sunucu tarafından yapılır.
      allow write: if false;
    }
  }
}
