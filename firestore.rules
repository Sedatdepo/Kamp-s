
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- YARDIMCI FONKSİYONLAR ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function isTeacher() {
      // Bir kullanıcının 'teachers' koleksiyonunda belgesi varsa öğretmendir.
      return isSignedIn() && exists(/databases/$(database)/documents/teachers/$(request.auth.uid));
    }
    
    // Bir sınıfın sahibi olan öğretmen mi? (Multi-tenant için en önemli kural)
    // Sadece kendi olusturduğu sınıfa erişebilir.
    function isClassOwner(classId) {
      let classDoc = get(/databases/$(database)/documents/classes/$(classId));
      return isTeacher() && classDoc.data.teacherId == request.auth.uid;
    }
    
    // Bir öğrencinin belirtilen sınıfta olup olmadığını kontrol eder.
    function isStudentInClass(classId) {
       // Öğrencinin kendi profil belgesindeki classId'ye bakar.
       let studentDoc = get(/databases/$(database)/documents/students/$(request.auth.uid));
       return studentDoc.data.classId == classId;
    }
    
    // Bir kaynağın (ödev, risk faktörü vb.) sahibi olan öğretmen mi?
    function isResourceOwner() {
        return isTeacher() && request.auth.uid == request.resource.data.teacherId;
    }
    
    // Var olan bir kaynağın sahibi mi? (Güncelleme/Silme için)
    function isExistingResourceOwner(resourceId, collectionName) {
        let resourceDoc = get(/databases/$(database)/documents/$(collectionName)/$(resourceId));
        return isTeacher() && resourceDoc.data.teacherId == request.auth.uid;
    }

    // --- GENEL GİRİŞ (HERKESE AÇIK) ---
    match /classCodes/{classCode} {
        // Öğrencinin sınıf kodunu kontrol edebilmesi için okumaya izin ver.
        allow get: if true;
        // Sadece öğretmenler sınıf kodu oluşturabilir/güncelleyebilir/silebilir.
        allow write: if isTeacher();
    }

    // --- ÖĞRENCİLER ---
    match /students/{studentId} {
        // Öğrenci sadece kendi belgesini okuyabilir ve güncelleyebilir.
        allow get, update: if isSignedIn() && isOwner(studentId);

        // Öğretmen, sadece kendi oluşturduğu sınıflardaki öğrencileri okuyabilir.
        // Bu sorgularda `where('teacherId', '==', request.auth.uid)` kullanılmasını zorunlu kılar.
        allow list: if isTeacher();

        // Bir öğretmen, sadece kendi `teacherId`'sine sahip bir öğrenci oluşturabilir.
        allow create: if isResourceOwner();
        
        // Bir öğretmen, sadece kendi `teacherId`'sine sahip bir öğrenciyi silebilir.
        allow delete: if isTeacher() && get(/databases/$(database)/documents/students/$(studentId)).data.teacherId == request.auth.uid;
    }
    
    // --- ÖĞRETMEN PROFİLİ ---
    match /teachers/{teacherId} {
      // Oturum açmış herkes öğretmen profillerini okuyabilir.
      allow read: if isSignedIn();
      // Sadece profilin sahibi yazma/güncelleme yapabilir.
      allow write: if isOwner(teacherId);
    }
    
    // --- SINIFLAR VE İÇERİKLERİ ---
    match /classes/{classId} {
      // Öğretmen, sadece kendi sınıfını okuyabilir.
      // Öğrenci, sadece kendi dahil olduğu sınıfı okuyabilir.
      allow get: if (isTeacher() && isClassOwner(classId)) || (isSignedIn() && isStudentInClass(classId));
      
      // Öğretmen sadece kendi 'teacherId'sini içeren sınıfları listeleyebilir.
      allow list: if isTeacher();
      
      // Öğretmen sadece kendi `teacherId`'sini içeren bir sınıf oluşturabilir.
      allow create: if isResourceOwner();
      
      // Öğretmen sadece kendi sınıfını güncelleyebilir/silebilir.
      allow update, delete: if isClassOwner(classId);

      // --- SINIF İÇİ ÖDEVLER ---
      match /homeworks/{homeworkId} {
        // Sınıfın sahibi öğretmen ve o sınıftaki öğrenciler ödevi okuyabilir.
        allow read: if (isTeacher() && isClassOwner(classId)) || (isSignedIn() && isStudentInClass(classId));
        // Sadece sınıfın sahibi öğretmen ödev yazabilir/silebilir.
        allow write: if isClassOwner(classId);

        // Ödev Teslimleri
        match /submissions/{submissionId} {
            // Sınıf sahibi öğretmen veya teslim eden öğrenci okuyabilir.
            allow read: if (isTeacher() && isClassOwner(classId)) || (isSignedIn() && isOwner(resource.data.studentId));
            // Sadece öğrenci teslimat oluşturabilir.
            allow create: if isSignedIn() && isOwner(request.resource.data.studentId);
            // Teslimatı sadece öğrencinin kendisi veya öğretmen (not vermek için) güncelleyebilir.
            allow update: if (isSignedIn() && isOwner(resource.data.studentId)) || (isTeacher() && isClassOwner(classId));
        }
      }
      
      // --- SINIF İÇİ TARTIŞMA PANOSU ---
      match /discussionTopics/{topicId} {
        allow read: if (isTeacher() && isClassOwner(classId)) || (isSignedIn() && isStudentInClass(classId));
        allow write: if isClassOwner(classId);

        match /posts/{postId} {
          allow read: if (isTeacher() && isClassOwner(classId)) || (isSignedIn() && isStudentInClass(classId));
          // Sadece o sınıftaki öğrenciler post oluşturabilir.
          allow create: if isSignedIn() && isStudentInClass(classId) && isOwner(request.resource.data.studentId);
          // Postu sadece öğretmen silebilir.
          allow delete: if isClassOwner(classId);
        }
      }
    }
    
    // --- ÖĞRETMENE ÖZEL GENEL KOLEKSİYONLAR ---
    match /riskFactors/{riskFactorId} {
        allow read: if isSignedIn(); 
        allow create: if isResourceOwner();
        allow update, delete: if isExistingResourceOwner(riskFactorId, 'riskFactors');
    }

    match /lessons/{lessonId} {
        allow read: if isSignedIn();
        allow create: if isResourceOwner();
        allow update, delete: if isExistingResourceOwner(lessonId, 'lessons');
    }

    match /clubs/{clubId} {
        allow read: if isSignedIn();
        allow create: if isResourceOwner();
        allow update, delete: if isExistingResourceOwner(clubId, 'clubs');
    }

    match /surveys/{surveyId} {
        allow read: if isSignedIn();
        allow write: if isTeacher();
    }
    
    // --- ÖĞRENCİYE ÖZEL KOLEKSİYONLAR (KENDİSİ VE ÖĞRETMENİ ERİŞEBİLİR) ---
    match /infoForms/{studentId} {
      allow read, write: if (isSignedIn() && isOwner(studentId)) || (isTeacher() && get(/databases/$(database)/documents/students/$(studentId)).data.teacherId == request.auth.uid);
    }
    
    match /surveyResponses/{responseId} {
        allow create: if isSignedIn();
        allow read: if isTeacher();
    }
    
    match /messages/{messageId} {
      allow read, write: if isSignedIn() && request.auth.uid in resource.data.participants;
    }
  }
}
