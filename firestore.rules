
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // UYARI: Bu kural geçici olarak hata teşhisi için eklenmiştir.
    // Uygulamanızı canlıya almadan önce MUTLAKA daha güvenli kurallarla değiştirin.
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
