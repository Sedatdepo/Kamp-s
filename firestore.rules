
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Geliştirme aşaması için geçici kural:
    // Sadece oturum açmış kullanıcıların okuma ve yazma erişimi vardır.
    // DİKKAT: Bu kuralları canlıya almadan önce kesinlikle daha güvenli hale getirin.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
