
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Public access for student login ---
    // Allows anyone to check if a class code is valid.
    match /classCodes/{code} {
      allow get: if true;
    }

    // --- Student Data ---
    // Allow ANYONE to read student data. This is necessary for the login flow to find
    // the student document before they are authenticated.
    // WARNING: This makes all student data publicly readable.
    // Write access is still restricted to authenticated users.
    match /students/{studentId} {
        allow read: if true;
        allow write: if request.auth != null;
    }

    // --- General Development Rule ---
    // Fallback rule: Allows all other read/write operations for any SIGNED-IN user.
    // This no longer applies to /students collection for read operations.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
