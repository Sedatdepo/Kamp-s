
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isTeacher() {
      // A user is a teacher if a document with their UID exists in the /teachers collection.
      return request.auth != null && exists(/databases/$(database)/documents/teachers/$(request.auth.uid));
    }
    
    // --- CORE TEACHER RULE (DO NOT REMOVE) ---
    // This rule is critical. It allows the isTeacher() function to work.
    match /teachers/{teacherId} {
      allow get: if request.auth != null;
      allow write: if isTeacher() && request.auth.uid == teacherId;
    }

    // --- PUBLIC RULES (No Auth Needed) ---
    match /publicViews/{viewId} {
      allow get: if true;
    }
    match /classCodes/{code} {
      allow get: if true;
    }
    
    // --- GENERAL AUTHENTICATED USER RULE ---
    // As per your request, any authenticated user can now read/write to these collections.
    // This will solve all permission errors in the student panel and voting pages.
    // The teacher wildcard rule is no longer needed as this covers teachers as well.

    match /students/{studentId} {
      allow read, write: if request.auth != null;
    }
    
    match /classes/{classId} {
      allow read, write: if request.auth != null;
    }

    match /lessons/{lessonId} {
      allow read, write: if request.auth != null;
    }
    
    match /clubs/{clubId} {
      allow read, write: if request.auth != null;
    }

    match /riskFactors/{riskFactorId} {
      allow read, write: if request.auth != null;
    }

    match /infoForms/{formId} {
      allow read, write: if request.auth != null;
    }
    
    match /classes/{classId}/homeworks/{homeworkId} {
      allow read, write: if request.auth != null;
    }
    
    match /classes/{classId}/homeworks/{homeworkId}/submissions/{submissionId} {
      allow read, write: if request.auth != null;
    }
    
    match /messages/{messageId} {
      allow read, write: if request.auth != null;
    }
  }
}
