rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    function isTeacher() {
      // Check if the user's UID exists in the teachers collection.
      return request.auth != null && exists(/databases/$(database)/documents/teachers/$(request.auth.uid));
    }

    // --- Global Teacher Rule ---
    // Teachers have full read/write access to the entire database.
    match /{document=**} {
      allow read, write: if isTeacher();
    }

    // --- Student Rules ---
    
    // Students can only read their own student document.
    match /students/{studentId} {
      allow get: if request.auth.uid == resource.data.authUid;
    }
  }
}
