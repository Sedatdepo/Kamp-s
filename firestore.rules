
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isTeacher() {
      return exists(/databases/$(database)/documents/teachers/$(request.auth.uid));
    }
    
    function isDataOwner(teacherId) {
      return isTeacher() && request.auth.uid == teacherId;
    }

    // --- Teacher Profiles ---
    match /teachers/{teacherId} {
      allow read: if isSignedIn();
      allow write: if isOwner(teacherId);
    }

    // --- Classes and Subcollections ---
    match /classes/{classId} {
      // Allow a teacher to LIST classes only if the query is filtered by their own teacherId.
      allow list: if isTeacher() && request.query.where.teacherId == request.auth.uid;
      
      // Allow a teacher to GET, UPDATE, or DELETE a single class document if they own it.
      allow get, update, delete: if isDataOwner(get(/databases/$(database)/documents/classes/$(classId)).data.teacherId);
      
      // Allow a teacher to CREATE a class if they set themselves as the teacherId.
      allow create: if isDataOwner(request.resource.data.teacherId);
      
      // --- Students within a class ---
      match /students/{studentId} {
        // Allow a teacher to access students in a class they own.
        // This relies on the get permission on the parent class document.
        allow read, write: if isDataOwner(get(/databases/$(database)/documents/classes/$(classId)).data.teacherId);
      }
      
      // --- Other subcollections (lessons, homeworks, etc.) ---
      match /{allChildren=**} {
         // Allow a teacher full access to all other subcollections within a class they own.
         allow read, write: if isDataOwner(get(/databases/$(database)/documents/classes/$(classId)).data.teacherId);
      }
    }
    
    // --- Top-level collections owned by teachers ---
    match /lessons/{lessonId} {
      // Allow a teacher to access lessons they created.
      allow read, write: if isDataOwner(resource.data.teacherId);
    }
    
    match /riskFactors/{riskFactorId} {
       // Allow a teacher to access risk factors they created.
       allow read, write: if isDataOwner(resource.data.teacherId);
    }
    
     match /questions/{questionId} {
       // Allow a teacher to access questions they created.
       allow read, write: if isDataOwner(resource.data.teacherId);
    }
    
     match /kazanims/{kazanimId} {
       // Allow a teacher to access learning objectives they created.
       allow read, write: if isDataOwner(resource.data.teacherId);
    }

    // --- Publicly readable collections ---
    match /classCodes/{code} {
      allow get: if isSignedIn();
    }
  }
}
