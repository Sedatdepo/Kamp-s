
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function isTeacher() {
      // Bir kullanıcının 'teachers' koleksiyonunda belgesi varsa öğretmendir.
      return exists(/databases/$(database)/documents/teachers/$(request.auth.uid));
    }
    
    // Sınıfın sahibi olan öğretmen mi? (Tekil okuma/yazma için)
    function isClassOwner(classId) {
      // Öğretmen olmalı VE ilgili sınıfın 'teacherId' alanı kendi ID'si olmalı.
      let classDoc = get(/databases/$(database)/documents/classes/$(classId));
      return isTeacher() && classDoc.data.teacherId == request.auth.uid;
    }
    
    // --- STUDENTS ---
    match /students/{studentId} {
      // Teachers can read/write students they own. Client queries MUST filter by teacherId for list to work.
      allow read: if isTeacher() && 
                          (request.method == 'create' 
                              ? request.resource.data.teacherId == request.auth.uid 
                              : resource.data.teacherId == request.auth.uid);
      
      // A student can get their own document.
      allow get: if request.auth.uid == resource.data.authUid;
      
      // A student can update a limited set of fields on their own document.
      allow update: if request.auth.uid == resource.data.authUid && 
                    request.resource.data.diff(resource.data).affectedKeys()
                      .hasOnly(['risks', 'projectPreferences', 'clubPreferences', 'fcmTokens', 'needsPasswordChange', 'positiveSelections', 'negativeSelections', 'leadershipSelections']);
    }

    // --- ÖĞRETMEN PROFİLİ ---
    match /teachers/{teacherId} {
      allow read: if isSignedIn();
      allow write: if isOwner(teacherId);
    }
    
    // --- NEW RULE FOR TEACHER DATA ---
    match /teacherData/{teacherId} {
        allow read, write: if isOwner(teacherId);
    }
    
    // --- SINIFLAR ---
    match /classes/{classId} {
      // Öğretmenlerin YALNIZCA kendi sınıflarını listelemesine izin ver.
      allow list: if isTeacher() && request.query.where.teacherId == request.auth.uid;
      
      // Öğretmen kendi sınıfını okuyabilir. Öğrenciler de (şimdilik) tüm sınıfları okuyabilir.
      allow get: if isClassOwner(classId) || isSignedIn();
      
      // Öğretmen kendi sınıfını güncelleyebilir ve silebilir.
      allow update, delete: if isClassOwner(classId);
      
      // Öğretmen, 'teacherId'si kendisine ait olan bir sınıf oluşturabilir.
      allow create: if isTeacher() && request.resource.data.teacherId == request.auth.uid;

      // --- SINIF ALT KOLEKSİYONLARI ---
      match /{allChildren=**} {
        // Bir öğretmen, kendi sınıfının altındaki tüm belgelere tam erişime sahiptir.
        allow read, write: if isClassOwner(classId);
      }
    }
    
    // --- TOP-LEVEL KOLEKSİYONLAR (Öğretmene Özel) ---
    match /lessons/{lessonId} {
      allow read, write: if isTeacher() && resource.data.teacherId == request.auth.uid;
    }
    
    match /riskFactors/{riskFactorId} {
      allow read, write: if isTeacher() && resource.data.teacherId == request.auth.uid;
    }

    match /questions/{questionId} {
      allow read, write: if isTeacher() && resource.data.teacherId == request.auth.uid;
    }

    match /kazanims/{kazanimId} {
      allow read, write: if isTeacher() && resource.data.teacherId == request.auth.uid;
    }

    // --- GENEL ERİŞİM ---

    // classCodes koleksiyonuna, giriş yapmış tüm kullanıcıların okuma izni verelim.
    match /classCodes/{code} {
      allow get: if isSignedIn();
    }

    // STUDENT INFO FORMS
    match /infoForms/{studentId} {
      // The student and their teacher can read/write the form.
      allow read, write: if (isSignedIn() && get(/databases/$(database)/documents/students/$(studentId)).data.authUid == request.auth.uid) ||
                         (isTeacher() && get(/databases/$(database)/documents/students/$(studentId)).data.teacherId == request.auth.uid);
    }
  }
}
