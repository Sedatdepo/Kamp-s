
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isTeacher() {
      return request.auth != null && exists(/databases/$(database)/documents/teachers/$(request.auth.uid));
    }
    
    // Öğretmen profilleri
    match /teachers/{teacherId} {
      allow get: if request.auth != null;
      allow write: if isTeacher() && request.auth.uid == teacherId;
    }
    
    // Öğretmenler için genel yazma/okuma yetkisi
    match /{document=**} {
      allow read, write: if isTeacher();
    }

    // Herkese açık görünümler ve sınıf kodları
    match /publicViews/{viewId} { allow read: if true; }
    match /classCodes/{code} { allow read: if true; }
    
    // Kimliği doğrulanmış kullanıcılar için okuma izinleri
    match /lessons/{lessonId} { allow read: if request.auth != null; }
    match /clubs/{clubId} { allow read: if request.auth != null; }
    match /riskFactors/{riskFactorId} { allow read: if request.auth != null; }
    
    // Sınıf bilgileri - kimliği doğrulanmış kullanıcılar okuyabilir
    match /classes/{classId} { 
      allow read: if request.auth != null; 
    }
    
    // Öğrenci verileri - güvenli okuma ve güncelleme
    match /students/{studentId} {
      // Herkes okuyabilir (sınıf listesi gösterimi için gerekli)
      allow read: if true; 
      allow update: if request.auth != null 
        && (resource.data.authUid == request.auth.uid 
            || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['authUid'])
            || !('authUid' in resource.data) 
            || resource.data.authUid == null 
            || resource.data.authUid == '');
    }

    // Bilgi formları - sadece kendi formunu yazabilir
    match /infoForms/{formId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    // Ödevler - okuma izni
    match /classes/{classId}/homeworks/{homeworkId} {
      allow read: if request.auth != null;
    }
    
    // Ödev gönderileri - kendi gönderisini oluşturabilir/güncelleyebilir
    match /classes/{classId}/homeworks/{homeworkId}/submissions/{submissionId} {
      allow create, read, write: if request.auth != null;
    }
    
    // Mesajlar - kimliği doğrulanmış kullanıcılar
    match /messages/{messageId} {
      allow read, create, update, list: if request.auth != null;
    }
  }
}
