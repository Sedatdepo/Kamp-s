
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isTeacher() {
      return exists(/databases/$(database)/documents/teachers/$(request.auth.uid));
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isSignedIn() {
      return request.auth != null;
    }
    
    match /classes/{classId} {
      allow read, write: if isTeacher();
      // Öğrenciler sadece kendi kayıtlı oldukları sınıfın belgesini okuyabilir.
      allow get: if exists(/databases/$(database)/documents/classes/$(classId)/students/$(request.auth.uid));

      match /students/{studentId} {
        allow read, create, update, delete: if isTeacher();
        // Öğrenci kendi bilgilerini okuyabilir/güncelleyebilir
        allow get, update: if isOwner(studentId);
      }

      match /homeworks/{homeworkId} {
        allow read, write: if isTeacher();
        // Öğrenci, kayıtlı olduğu sınıftaki ödevleri okuyabilir.
        allow read: if exists(/databases/$(database)/documents/classes/$(classId)/students/$(request.auth.uid));

        match /submissions/{submissionId} {
          allow read, write: if isTeacher();
          allow list: if isTeacher();
          allow create: if isOwner(request.resource.data.studentId);
        }
      }
    }
    
    match /students/{studentId} {
      allow get, update: if isOwner(studentId) || isTeacher();
      // Bu kök koleksiyona sadece öğretmenler yazabilir veya listeleyebilir.
      // Öğrenciler kendi belgelerini /classes/{classId}/students/{studentId} yolundan günceller.
      allow list, create, delete: if isTeacher();
    }

    match /teachers/{teacherId} {
        allow read: if isSignedIn();
        allow write: if isOwner(teacherId);
    }

    match /infoForms/{formId} {
      // formId öğrencinin UID'si ile aynıdır.
      allow read, write: if isTeacher();
      allow create, update, get: if isOwner(formId);
    }
    
    match /riskFactors/{factorId} {
      allow read, write: if isTeacher();
    }

    match /lessons/{lessonId} {
      allow read: if isSignedIn();
      allow write: if isTeacher();
    }
    
    match /messages/{messageId} {
      allow read: if request.auth.uid in resource.data.participants;
      // Öğretmen ve öğrenciler mesaj gönderebilir.
      // Gönderen kişi kendi auth.uid'si olmalı ve alıcı da participants listesinde olmalı.
      allow create: if request.auth.uid == request.resource.data.senderId &&
                     request.resource.data.receiverId in request.resource.data.participants;
    }
    
    match /roles_teacher/{uid} {
        allow read, write: if false; // Bu koleksiyona doğrudan erişim olmamalı.
    }

    match /studentCredentials/{uid} {
        allow read, write: if false; // Sadece backend/admin erişebilmeli.
    }

     match /surveys/{surveyId} {
        allow get, list: if isSignedIn();
        allow create, update, delete: if isTeacher();
    }
    match /surveyResponses/{responseId} {
        allow create: if isSignedIn();
        allow read, list: if isTeacher();
        allow update, delete: if isTeacher();
    }

    // New Rules for Question Bank
    match /kazanims/{kazanimId} {
      allow read: if isSignedIn();
      allow create, update, delete: if request.auth.uid == request.resource.data.teacherId;
    }

    match /questions/{questionId} {
      allow read: if isSignedIn();
      allow create, update, delete: if request.auth.uid == request.resource.data.teacherId;
    }
  }
}
