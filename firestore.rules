
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- GENEL OKUMA KURALI (HERKESE AÇIK) ---
    // UYARI: Bu kural veritabanınızdaki tüm verileri herkes tarafından okunabilir yapar.
    match /{document=**} {
      allow read: if true;
    }

    // --- YAZMA KURALI (DAHA KISITLI) ---
    function isTeacher() {
      // Öğretmen olup olmadığını kontrol eden fonksiyon.
      return request.auth != null && exists(/databases/$(database)/documents/teachers/$(request.auth.uid));
    }

    // Öğretmenler kendi profillerini yazabilir.
    match /teachers/{teacherId} {
      allow write: if isTeacher() && request.auth.uid == teacherId;
    }

    // Öğrencilerin ve öğretmenlerin yazma kuralları
    match /students/{studentId} {
      allow update: if isTeacher() || 
                    (request.auth != null && request.auth.uid == resource.data.authUid) ||
                    // Öğrencinin ilk girişte kendi kimliğini kaydetmesine izin ver
                    (request.auth != null && (!('authUid' in resource.data) || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['authUid'])));
      allow create, delete: if isTeacher();
    }

    // Bilgi formlarını sadece öğrencinin kendisi veya öğretmen yazabilir
    match /infoForms/{formId} {
        allow write: if isTeacher() || (request.auth != null && request.resource.data.authUid == request.auth.uid);
    }
    
    // Ödev teslimatını sadece öğrenci yapabilir, öğretmen not verebilir (güncelleyebilir)
    match /classes/{classId}/homeworks/{homeworkId}/submissions/{submissionId} {
      allow create: if request.auth != null && request.resource.data.studentAuthUid == request.auth.uid;
      allow write: if isTeacher();
    }
    
    // Mesajlaşma kuralları
    match /messages/{messageId} {
      allow create: if request.auth != null && request.auth.uid in request.resource.data.participants;
      // Sadece öğretmen veya mesajı alan öğrenci (okundu bilgisi için) güncelleyebilir
      allow update: if isTeacher() || (request.auth != null && resource.data.receiverId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']));
      allow delete: if isTeacher();
    }
    
    // Bu koleksiyonlara sadece öğretmenler yazabilir
    match /lessons/{lessonId} { allow write: if isTeacher(); }
    match /clubs/{clubId} { allow write: if isTeacher(); }
    match /riskFactors/{riskFactorId} { allow write: if isTeacher(); }
    match /classes/{classId} { allow write: if isTeacher(); }
    match /classes/{classId}/homeworks/{homeworkId} { allow write: if isTeacher(); }
  }
}
