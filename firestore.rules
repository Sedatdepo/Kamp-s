
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- TEMEL YARDIMCI FONKSİYON ---
    function isSignedIn() {
      return request.auth != null;
    }

    // --- EN BASİT KURAL ---
    // Giriş yapmış herhangi bir kullanıcı, herhangi bir belgeyi okuyabilir, yazabilir, güncelleyebilir ve silebilir.
    // BU KURAL GELİŞTİRME AŞAMASINDAKİ İZİN HATALARINI TAMAMEN ORTADAN KALDIRIR.
    match /{path=**} {
      allow read, write: if isSignedIn();
    }
    
    // Not: Öğrencinin giriş yapabilmesi için, kimliği doğrulanmamış kullanıcının
    // 'students' ve 'classes' koleksiyonlarını sorgulamasına izin vermemiz gerekiyor.
    match /students/{studentId} {
      allow list: if true;
    }
    match /classes/{classId} {
        allow list: if true;
    }
  }
}
