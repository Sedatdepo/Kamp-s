rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // UYARI: Bu kurallar güvensizdir ve sadece geliştirme için uygundur.
    // Herkesin veritabanınızı okumasına, yazmasına ve silmesine izin verir.
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
