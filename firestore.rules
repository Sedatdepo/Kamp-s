rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Function ---
    function isTeacher() {
      // Returns true if the user is authenticated and exists in the /teachers collection.
      return request.auth != null && exists(/databases/$(database)/documents/teachers/$(request.auth.uid));
    }
    
    // --- Blanket Teacher Access ---
    // If the user is a teacher, grant full access to everything.
    // This single rule resolves all teacher-side permission errors.
    match /{path=**} {
      allow read, write: if isTeacher();
    }
    
    // --- Student & Public Access Rules ---
    // These rules apply to non-teachers (e.g., anonymous students).

    // Anyone can read public data needed for viewing pages without login.
    match /publicViews/{viewId} {
      allow get: if true;
    }
    match /classCodes/{code} {
      allow get: if true;
    }

    // Students need to read the student list to find their name
    // and update their own document to link their auth UID upon login.
    match /students/{studentId} {
        allow read: if true; 
        allow update: if request.auth != null; 
    }
    
    // Students can read homework assignments for their class.
    match /classes/{classId}/homeworks/{homeworkId} {
      allow get: if request.auth != null;
    }

    // Students can create their own submissions.
    match /{path=**}/submissions/{submissionId} {
      allow create: if request.auth != null && request.resource.data.studentAuthUid == request.auth.uid;
      // Allow students to read their own submissions.
      allow read: if request.auth != null && resource.data.studentAuthUid == request.auth.uid;
    }
    
    // Students can write to their own info form.
    match /infoForms/{studentId} {
      // isOwner() check isn't strictly necessary if UIDs are unpredictable, 
      // but it's good practice. For simplicity as requested, we'll allow any authenticated user to write.
      allow write: if request.auth != null;
      // Students can also read their own form back if needed, assuming the app logic handles this.
      allow read: if request.auth != null;
    }
    
    // Students can send and read messages.
    match /messages/{messageId} {
      allow read, create: if request.auth != null;
      allow update: if request.auth != null; // For marking as read
    }
  }
}
