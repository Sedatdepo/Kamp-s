
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isTeacher(userId) {
      // A user is a teacher if they have a document in the /teachers collection
      return exists(/databases/$(database)/documents/teachers/$(userId));
    }
    
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Publicly readable views of data, only writable by the class teacher
    match /publicViews/{viewId} {
        allow get: if true;
        allow write: if isTeacher(request.auth.uid) &&
                      exists(/databases/$(database)/documents/classes/$(viewId)) &&
                      get(/databases/$(database)/documents/classes/$(viewId)).data.teacherId == request.auth.uid;
    }

    // Class codes for student portal entry
    match /classCodes/{code} {
        allow get: if true;
        // Only teachers can create/update class codes
        allow write: if isTeacher(request.auth.uid);
    }
    
    // Teachers can manage their own classes
    match /classes/{classId} {
        allow read: if request.auth != null;
        allow write: if isTeacher(request.auth.uid) && request.resource.data.teacherId == request.auth.uid;
    }
    
    // Students collection
    match /students/{studentId} {
        allow get: if request.auth != null && (isTeacher(request.auth.uid) || (resource.data.authUid != null && isOwner(resource.data.authUid)));
        allow list: if isTeacher(request.auth.uid);
        allow create: if isTeacher(request.auth.uid);
        allow delete: if isTeacher(request.auth.uid);
        allow update: if request.auth != null && (
          // Teachers can update any student data
          isTeacher(request.auth.uid) ||
          // A student can claim their document with an authUid if not already claimed
          (
            request.resource.data.authUid == request.auth.uid &&
            resource.data.authUid == null &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['authUid'])
          ) ||
          // An authenticated student can update their own preferences/selections
          (
            isOwner(resource.data.authUid) &&
            (
                request.resource.data.diff(resource.data).affectedKeys().hasAny(['projectPreferences', 'clubPreferences', 'risks', 'positiveSelections', 'negativeSelections', 'leadershipSelections'])
            )
          )
        );
    }

    // Messages between users
    match /messages/{messageId} {
      allow get: if request.auth != null && request.auth.uid in resource.data.participants;
      allow list: if request.auth != null && request.query.where['participants']['array-contains'] == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.senderId == request.auth.uid;
      allow update: if request.auth != null && (isOwner(resource.data.receiverId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead'])); // Only receiver can mark as read
      allow delete: if false;
    }
    
    // Teacher profiles
    match /teachers/{teacherId} {
        allow read, write: if isOwner(teacherId);
    }

    // Lessons, Clubs, RiskFactors are managed by teachers
    match /lessons/{lessonId} {
        allow read: if request.auth != null;
        allow write: if isTeacher(request.auth.uid);
    }
    match /clubs/{clubId} {
        allow read: if request.auth != null;
        allow write: if isTeacher(request.auth.uid);
    }
    match /riskFactors/{riskFactorId} {
        allow read: if request.auth != null;
        allow write: if isTeacher(request.auth.uid);
    }

    // Student info forms
    match /infoForms/{formId} {
        allow read: if request.auth != null; // Teachers can read, students can read their own
        allow write: if request.auth != null && request.auth.uid == request.resource.data.studentId;
    }

    // Homeworks and submissions
    match /classes/{classId}/homeworks/{homeworkId} {
        allow read: if request.auth != null;
        allow write: if isTeacher(request.auth.uid);
        
        match /submissions/{submissionId} {
            allow read: if request.auth != null;
            allow create: if request.auth != null; // Students submit
            allow update: if isTeacher(request.auth.uid); // Teacher grades/gives feedback
            allow delete: if isTeacher(request.auth.uid);
        }
    }

     // Teacher specific data store
    match /teacherData/{teacherId} {
      allow read, write: if isOwner(teacherId);
    }
  }
}
