rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- YARDIMCI FONKSİYONLAR ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // DİKKAT: Bu fonksiyonu sadece TEKİL okuma (get) ve yazma (write) işlemlerinde kullan.
    // Listeleme (list) sorgularında ASLA bunu kullanma.
    function isTeacherProfile() {
      return exists(/databases/$(database)/documents/teachers/$(request.auth.uid));
    }

    // --- 1. ÖĞRENCİ GİRİŞİ (GOOGLE CLASSROOM TARZI) ---
    // Öğrencilerin sınıf kodu ve numara ile kendilerini bulabilmesi için
    // Ana 'students' koleksiyonu
    match /students/{studentId} {
      // Hata alan kısım burasıydı. Giriş yapmamış birinin sorgu atabilmesi için:
      // Güvenlik notu: Bu kural veriyi dışa açar ancak öğrenci girişi için gereklidir.
      allow list: if true; 
      
      // Öğrenci giriş yaptıktan sonra kendi verisini okuyabilir/güncelleyebilir
      allow get, update: if isOwner(studentId);
      
      // Öğretmenler her şeyi yapabilir (listeleme hariç, onu aşağıda çözdük)
      allow create, delete: if isSignedIn() && isTeacherProfile();
    }

    // --- 2. ÖĞRETMEN PANELİ VE SINIFLAR ---
    match /classes/{classId} {
      
      // KRİTİK DÜZELTME: Öğretmen paneli hatasını çözen satır.
      // Listeleme yaparken 'exists' yerine belgenin üzerindeki 'teacherId'ye bakıyoruz.
      // Frontend sorgun şu şekilde OLMALIDIR: .where('teacherId', '==', user.uid)
      allow list: if isSignedIn() && resource.data.teacherId == request.auth.uid;

      // Tekil sınıf okuma ve yazma işlemleri
      allow get, create, update, delete: if isSignedIn() && (resource.data.teacherId == request.auth.uid || request.resource.data.teacherId == request.auth.uid);

      // --- SINIFIN ÖĞRENCİLERİ ---
      match /students/{studentId} {
         // Öğretmen bu sınıfın sahibiyse öğrencileri yönetebilir
         allow read, write: if isSignedIn() && get(/databases/$(database)/documents/classes/$(classId)).data.teacherId == request.auth.uid;
         
         // Öğrenci kendi sınıfındaki arkadaşlarını görebilir
         allow list, get: if isSignedIn() && get(/databases/$(database)/documents/students/$(request.auth.uid)).data.classId == classId;
      }

      // --- ÖDEVLER ---
      match /homeworks/{homeworkId} {
        // Sınıfın öğretmeni okuyup yazabilir
        allow read, write: if isSignedIn() && get(/databases/$(database)/documents/classes/$(classId)).data.teacherId == request.auth.uid;
        // Öğrenci ödevleri görebilir
        allow list, get: if isSignedIn() && get(/databases/$(database)/documents/students/$(request.auth.uid)).data.classId == classId;

        // --- TESLİMLER ---
        match /submissions/{submissionId} {
          allow read: if isSignedIn(); // Detaylı yetki gerekirse burası özelleştirilebilir
          allow create: if isSignedIn() && request.resource.data.studentId == request.auth.uid;
          allow update: if isSignedIn() && resource.data.studentId == request.auth.uid;
        }
      }
    }

    // --- DİĞER KOLEKSİYONLAR ---
    
    match /teachers/{teacherId} {
       allow read: if isSignedIn();
       allow write: if isOwner(teacherId);
    }

    match /infoForms/{formId} {
       allow read, write: if isSignedIn(); 
    }
    
    match /riskFactors/{factorId} {
       allow read, write: if isSignedIn() && isTeacherProfile();
    }

    match /lessons/{lessonId} {
       allow read: if isSignedIn();
       allow write: if isSignedIn() && isTeacherProfile();
    }
    
    match /messages/{messageId} {
       allow read, write: if isSignedIn() && request.auth.uid in resource.data.participants;
    }

    match /surveys/{surveyId} {
       allow read: if isSignedIn();
       allow write: if isSignedIn() && isTeacherProfile();
    }
    
    match /surveyResponses/{responseId} {
       allow create: if isSignedIn();
       allow read: if isSignedIn() && isTeacherProfile();
    }
  }
}