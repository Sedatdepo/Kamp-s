
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if the user ID exists in the /teachers collection.
    // This is the single source of truth for "is a teacher".
    function isTeacher() {
      // This is safe because of the more-specific rule for /teachers/{teacherId} below.
      return request.auth != null && exists(/databases/$(database)/documents/teachers/$(request.auth.uid));
    }
    
    // --- CORE SECURITY RULES ---

    // This rule is CRITICAL. It allows the isTeacher() function to work without causing a recursive loop.
    // Any authenticated user can check for the existence of a teacher document.
    match /teachers/{teacherId} {
      allow get: if request.auth != null;
    }

    // "God Mode" for the teacher. If the user is a teacher, they can do anything.
    // This single rule grants all read (get, list) and write (create, update, delete)
    // permissions across the entire database. This is simple and effective for a
    // single-admin application.
    match /{path=**} {
      allow read, write: if isTeacher();
    }
    
    // ---- STUDENT & PUBLIC RULES ----
    // The rules below ONLY apply if the user is NOT a teacher, because a teacher
    // would have already been granted access by the "God Mode" rule above.
    
    match /publicViews/{viewId} { allow get: if true; }
    match /classCodes/{code} { allow get: if true; }
    
    // Students can read lists of these collections for selection purposes.
    match /lessons/{lessonId} { allow read: if request.auth != null; }
    match /clubs/{clubId} { allow read: if request.auth != null; }
    match /riskFactors/{riskFactorId} { allow read: if request.auth != null; }
    
    // Students can get their specific class document.
    match /classes/{classId} { 
      allow get: if request.auth != null; 
    }
    
    // Student login process: anyone can read the list to find their name.
    // Students can write their auth UID after anonymous login.
    match /students/{studentId} {
      allow read: if true; 
      allow update: if request.auth != null && request.resource.data.authUid == request.auth.uid;
    }

    // Students can manage their own info form
    match /infoForms/{formId} {
        allow read, write: if request.auth != null && get(/databases/$(database)/documents/students/$(formId)).data.authUid == request.auth.uid;
    }
    
    // Homework submissions
    match /classes/{classId}/homeworks/{homeworkId} {
        allow get: if request.auth != null;
    }
    match /classes/{classId}/homeworks/{homeworkId}/submissions/{submissionId} {
      allow create: if request.auth != null && request.resource.data.studentAuthUid == request.auth.uid;
      allow read: if request.auth != null && resource.data.studentAuthUid == request.auth.uid;
    }
    
    // Messaging rules for participants
    match /messages/{messageId} {
      allow list, read, create, update: if request.auth != null && request.auth.uid in resource.data.participants;
    }
  }
}
