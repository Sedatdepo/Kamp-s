
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- General Development Rule ---
    // This allows all read/write operations for any signed-in user.
    // This is NOT secure for production. Use with caution.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
