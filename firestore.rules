
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isTeacher() {
      // This is safe because of the more-specific rule for /teachers below.
      return request.auth != null && exists(/databases/$(database)/documents/teachers/$(request.auth.uid));
    }
    
    // THIS RULE IS CRITICAL. It is more specific than the wildcard rule below.
    // Firestore evaluates this first for any access to /teachers/{id}.
    // It does NOT call isTeacher(), preventing a loop.
    match /teachers/{teacherId} {
      allow get: if request.auth != null;
    }

    // This is the "teacher god mode" rule. If a user is a teacher, they can
    // do anything to any document in the database (except what's handled by the
    // more specific /teachers rule above).
    match /{document=**} {
      allow read, write: if isTeacher();
    }
    
    // ---- STUDENT RULES ----
    // The rules below are for non-teachers, because a teacher would have already been granted access.
    
    match /publicViews/{viewId} { allow get: if true; }
    match /classCodes/{code} { allow get: if true; }
    
    // Students can read lists of these collections
    match /lessons/{lessonId} { allow read: if request.auth != null; }
    match /clubs/{clubId} { allow read: if request.auth != null; }
    match /riskFactors/{riskFactorId} { allow read: if request.auth != null; }
    
    // Students can read their own class info
    match /classes/{classId} { allow get: if request.auth != null; }
    
    // Anyone can read student list for login, and students can update their own authUid
    match /students/{studentId} {
      allow read: if true; 
      allow update(authUid): if request.auth != null;
    }

    // Students can read their own info form
    match /infoForms/{formId} {
        allow read, write: if request.auth != null && get(/databases/$(database)/documents/students/$(formId)).data.authUid == request.auth.uid;
    }

    // Students can read homeworks and read/create their own submissions
    match /classes/{classId}/homeworks/{homeworkId} {
        allow get: if request.auth != null;
    }
    match /classes/{classId}/homeworks/{homeworkId}/submissions/{submissionId} {
      allow create: if request.auth != null && request.resource.data.studentAuthUid == request.auth.uid;
      allow read: if request.auth != null && resource.data.studentAuthUid == request.auth.uid;
    }
    
    // Messaging rules for participants
    match /messages/{messageId} {
      allow list: if request.auth != null && request.query.where['participants']['array-contains'] == request.auth.uid;
      allow read, create, update: if request.auth != null && request.auth.uid in resource.data.participants;
    }
  }
}
