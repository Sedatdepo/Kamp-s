
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function isTeacher() {
      // A user is a teacher if their UID exists in the /teachers collection.
      return exists(/databases/$(database)/documents/teachers/$(request.auth.uid));
    }
    
    // Checks if the requesting user is the owner of a specific class.
    function isClassOwner(classId) {
      // Must be a teacher AND the class's teacherId must be their own UID.
      let classDoc = get(/databases/$(database)/documents/classes/$(classId));
      return isTeacher() && classDoc.data.teacherId == request.auth.uid;
    }
    
    // --- STUDENTS ---
    match /students/{studentId} {
      // A teacher can list students, but the client query MUST filter by their teacherId.
      allow list: if isTeacher();
      
      // A teacher can get, create, or write to a student document if they own the student.
      allow get, write: if isTeacher() && (request.method == 'create' ? request.resource.data.teacherId == request.auth.uid : resource.data.teacherId == request.auth.uid);
      
      // A student can get their own document.
      allow get: if request.auth.uid == resource.data.authUid;
      
      // A student can update a limited set of fields on their own document.
      allow update: if request.auth.uid == resource.data.authUid && 
                    request.resource.data.diff(resource.data).affectedKeys()
                      .hasOnly(['risks', 'projectPreferences', 'clubPreferences', 'fcmTokens', 'needsPasswordChange', 'positiveSelections', 'negativeSelections', 'leadershipSelections']);
    }

    // --- TEACHER PROFILE ---
    match /teachers/{teacherId} {
      allow read: if isSignedIn();
      allow write: if isOwner(teacherId);
    }
    
    // --- TEACHER DATA (Archived docs, etc.) ---
    match /teacherData/{teacherId} {
        allow read, write: if isOwner(teacherId);
    }
    
    // --- CLASSES ---
    match /classes/{classId} {
      // A teacher can list classes, but the client query MUST filter by their teacherId.
      allow list: if isTeacher();
      
      // A teacher can read their own class. A student can read any class (for now).
      allow get: if isClassOwner(classId) || isSignedIn();
      
      // A teacher can update and delete their own class.
      allow update, delete: if isClassOwner(classId);
      
      // A teacher can create a class if the teacherId is their own.
      allow create: if isTeacher() && request.resource.data.teacherId == request.auth.uid;

      // --- CLASS SUBCOLLECTIONS ---
      match /{allChildren=**} {
        // A teacher has full access to all documents under their own class.
        allow read, write: if isClassOwner(classId);
      }
    }
    
    // --- TOP-LEVEL COLLECTIONS (Teacher-Specific) ---
    match /lessons/{lessonId} {
      allow read, write: if isTeacher() && resource.data.teacherId == request.auth.uid;
    }
    
    match /riskFactors/{riskFactorId} {
      allow read, write: if isTeacher() && resource.data.teacherId == request.auth.uid;
    }

    match /questions/{questionId} {
      allow read, write: if isTeacher() && resource.data.teacherId == request.auth.uid;
    }

    match /kazanims/{kazanimId} {
      allow read, write: if isTeacher() && resource.data.teacherId == request.auth.uid;
    }
    
    match /clubs/{clubId} {
      allow read, write: if isTeacher() && resource.data.teacherId == request.auth.uid;
    }

    // --- GENERAL ACCESS ---
    match /classCodes/{code} {
      allow get: if isSignedIn();
    }

    // STUDENT INFO FORMS
    match /infoForms/{studentId} {
      // The student and their teacher can read/write the form.
      allow read, write: if (isSignedIn() && get(/databases/$(database)/documents/students/$(studentId)).data.authUid == request.auth.uid) ||
                         (isTeacher() && get(/databases/$(database)/documents/students/$(studentId)).data.teacherId == request.auth.uid);
    }

    // MESSAGES
    match /messages/{messageId} {
      // A user can read/write a message if they are a participant.
      allow read, write: if request.auth.uid in resource.data.participants;
    }
  }
}
