
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- YARDIMCI FONKSİYONLAR ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function isTeacher() {
      // Bir kullanıcının 'teachers' koleksiyonunda belgesi varsa öğretmendir.
      return exists(/databases/$(database)/documents/teachers/$(request.auth.uid));
    }
    
    // Sınıfın sahibi olan öğretmen mi? (Tekil okuma/yazma için)
    function isClassOwner(classId) {
      // Öğretmen olmalı VE ilgili sınıfın 'teacherId' alanı kendi ID'si olmalı.
      let classDoc = get(/databases/$(database)/documents/classes/$(classId));
      return isTeacher() && classDoc.data.teacherId == request.auth.uid;
    }
    
    function isStudentInClass(classId) {
       // DOĞRU YAPI: Öğrencinin kendi belgesindeki classId'ye bak.
       return get(/databases/$(database)/documents/students/$(request.auth.uid)).data.classId == classId;
    }
    
    // --- SINIF KODLARI (GİRİŞ İÇİN) ---
    match /classCodes/{classCode} {
        // GÜNCELLEME: Herkes (kimliksiz kullanıcılar dahil) sınıf kodunun varlığını kontrol edebilir.
        // Bu, öğrenci girişinin ilk adımı için gereklidir.
        allow get: if true;
        // Sadece öğretmenler sınıf kodu oluşturabilir/güncelleyebilir/silebilir.
        allow write: if isTeacher();
    }

    // --- ÖĞRENCİ YÖNETİMİ ---
    match /students/{studentId} {
        // Öğrenciler sadece kendi bilgilerini görebilir ve güncelleyebilir.
        allow get, update: if isOwner(studentId);

        // Öğretmenler, kendi sınıflarındaki öğrencileri okuyabilir.
        allow read: if isTeacher(); // More specific rules might be needed depending on query patterns

        // Öğretmenler, kendi sınıflarına öğrenci ekleyebilir.
        allow create: if isTeacher() && isClassOwner(request.resource.data.classId);

        // Öğretmenler, yalnızca kendi sınıfları içindeki öğrencileri güncelleyebilir.
        allow update: if isTeacher() && isClassOwner(resource.data.classId) && isClassOwner(request.resource.data.classId);
        
        // Öğretmenler, yalnızca kendi sınıflarındaki öğrencileri silebilir.
        allow delete: if isTeacher() && isClassOwner(resource.data.classId);
    }
    
    // --- ÖĞRETMEN PROFİLİ ---
    match /teachers/{teacherId} {
      allow read: if isSignedIn();
      allow write: if isOwner(teacherId);
    }
    
    // --- SINIFLAR ---
    match /classes/{classId} {
      // BİR OGRETMEN, SADECE KENDI 'teacherId'SINE SAHIP SINIFLARI OKUYABILIR (LISTELEYEBILIR VEYA TEKIL GETIREBILIR)
      allow read: if isTeacher() && resource.data.teacherId == request.auth.uid;
      
      // Öğretmen sadece kendi oluşturduğu sınıfı yazabilir/silebilir.
      allow update, delete: if isClassOwner(classId);
      
      // YENİ KURAL: Bir öğretmen, kendi teacherId'sini içeren bir sınıf oluşturabilir.
      allow create: if isTeacher() && request.resource.data.teacherId == request.auth.uid;

      // Öğrenci sadece kendi dahil olduğu sınıfı okuyabilir.
      allow get: if isStudentInClass(classId);
      
      // SINIF ALT KOLEKSİYONLARI (ÖDEVLER VB.)
      match /homeworks/{homeworkId} {
        allow read, write: if isClassOwner(classId); // Öğretmen okuyabilir, yazabilir.
        allow get: if isStudentInClass(classId); // Öğrenci okuyabilir.

        match /submissions/{submissionId} {
            allow read: if isClassOwner(classId) || isOwner(resource.data.studentId);
            allow create: if isOwner(request.resource.data.studentId);
            allow update: if isOwner(resource.data.studentId) || isClassOwner(classId);
        }
      }
      
      // YENİ: TARTIŞMA PANOSU KURALLARI
      match /discussionTopics/{topicId} {
        allow read: if isClassOwner(classId) || isStudentInClass(classId);
        allow create, update, delete: if isClassOwner(classId);

        match /posts/{postId} {
          allow read: if isClassOwner(classId) || isStudentInClass(classId);
          allow create: if isStudentInClass(classId) && request.resource.data.studentId == request.auth.uid;
          allow delete: if isClassOwner(classId); // Sadece öğretmen silebilir
        }
      }
    }
    
    // --- ÖĞRETMENE ÖZEL KOLEKSİYONLAR (Risk Faktörleri, Proje Dersleri, Kulüpler) ---
    function isResourceOwner() {
        return request.auth.uid == request.resource.data.teacherId;
    }
    function isExistingResourceOwner(resourceId, collectionName) {
        return get(/databases/$(database)/documents/$(collectionName)/$(resourceId)).data.teacherId == request.auth.uid;
    }

    match /riskFactors/{riskFactorId} {
        allow read: if isSignedIn(); 
        allow create: if isTeacher() && isResourceOwner();
        allow update, delete: if isTeacher() && isExistingResourceOwner(riskFactorId, 'riskFactors');
    }

    match /lessons/{lessonId} {
        allow read: if isSignedIn();
        allow create: if isTeacher() && isResourceOwner();
        allow update, delete: if isTeacher() && isExistingResourceOwner(lessonId, 'lessons');
    }

    match /clubs/{clubId} {
        allow read: if isSignedIn();
        allow create: if isTeacher() && isResourceOwner();
        allow update, delete: if isTeacher() && isExistingResourceOwner(clubId, 'clubs');
    }

    // --- ÖĞRENCİYE ÖZEL KOLEKSİYONLAR ---
    match /infoForms/{formId} {
      // Öğrenci kendi formunu yönetebilir, öğretmen ise tüm formları okuyabilir.
      allow get, create, update: if isOwner(formId); 
      allow list, read: if isTeacher(); 
    }
    
    match /messages/{messageId} {
      // Sadece mesajlaşmanın tarafları okuma/yazma yapabilir.
      allow read, write: if isSignedIn() && request.auth.uid in resource.data.participants;
    }
    
    match /surveys/{surveyId} {
        // Oturum açmış herkes (öğretmen ve öğrenci) anketleri okuyabilir
        allow read: if isSignedIn();
        // Sadece öğretmenler anket yazabilir/güncelleyebilir/silebilir
        allow write: if isTeacher();
    }
    
    match /surveyResponses/{responseId} {
        // Oturum açmış herkes (öğrenciler) anket cevabı oluşturabilir.
        allow create: if isSignedIn();
        // Sadece öğretmenler tüm cevapları okuyabilir.
        allow read: if isTeacher();
    }
  }
}
