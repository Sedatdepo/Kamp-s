
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isTeacher() {
      return exists(/databases/$(database)/documents/teachers/$(request.auth.uid));
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isSignedIn() {
      return request.auth != null;
    }
    
    // Öğrenci giriş yaparken sınıf kodunu sorgulayabilmeli
    match /classes/{classId} {
      allow list: if !isSignedIn(); // Sadece classCode ile sorgulama için
      allow read, write: if isTeacher();
      
      // Öğrenci kendi sınıf bilgilerini okuyabilir (giriş yaptıktan sonra)
      allow get: if isSignedIn() && get(/databases/$(database)/documents/students/$(request.auth.uid)).data.classId == classId;

      match /students/{studentId} {
        allow read, write: if isTeacher();
        allow get, update: if isOwner(studentId);
      }

      match /homeworks/{homeworkId} {
        allow read, write: if isTeacher();
        allow read: if isSignedIn() && get(/databases/$(database)/documents/students/$(request.auth.uid)).data.classId == classId;

        match /submissions/{submissionId} {
          allow read, write: if isTeacher();
          allow create: if isOwner(request.resource.data.studentId);
          allow read, update: if isOwner(submissionId);
        }
      }
    }
    
    // Öğrenci giriş yaparken öğrenci numarasını sorgulayabilmeli
    match /students/{studentId} {
      allow list: if !isSignedIn(); // classId ve studentNumber ile sorgulama için
      allow get, update: if isOwner(studentId) || isTeacher();
      allow read, write: if isTeacher();
    }

    match /teachers/{teacherId} {
        allow read: if request.auth != null;
        allow write: if isOwner(teacherId);
    }

    match /infoForms/{formId} {
      allow read, write: if isTeacher();
      allow read, create, update: if isOwner(formId);
    }
    
    match /riskFactors/{factorId} {
      allow read, write: if isTeacher();
    }

    match /lessons/{lessonId} {
      allow read: if request.auth != null;
      allow write: if isTeacher();
    }
    
    match /messages/{messageId} {
      allow read, write: if request.auth.uid in resource.data.participants;
    }
    
    match /roles_teacher/{uid} {
        allow read, write: if false;
    }

    match /kazanims/{kazanimId} {
      allow read: if request.auth != null;
      allow write: if isTeacher() && request.resource.data.teacherId == request.auth.uid;
    }

    match /questions/{questionId} {
      allow read: if isTeacher();
      allow write: if isTeacher() && request.resource.data.teacherId == request.auth.uid;
    }
    
    match /surveys/{surveyId} {
       allow get, list: if request.auth != null;
       allow create, update, delete: if isTeacher();
    }
    match /surveyResponses/{responseId} {
        allow create: if request.auth != null;
        allow read, list: if isTeacher();
        allow update, delete: if isTeacher();
    }
  }
}
