
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    function isTeacher() {
      // A user is a teacher if a document with their UID exists in the 'teachers' collection.
      return exists(/databases/$(database)/documents/teachers/$(request.auth.uid));
    }

    // --- Specific Rules to fix 'list' operations in Dev Environment ---

    // Allow teachers to LIST documents from collections if they are querying for their own documents.
    // This is necessary because the dev environment simulator is stricter than production with general rules.
    match /classes/{classId} {
      allow list: if isTeacher() && request.query.where.teacherId == request.auth.uid;
    }
    match /students/{studentId} {
      allow list: if isTeacher() && request.query.where.teacherId == request.auth.uid;
    }
    match /lessons/{lessonId} {
      allow list: if isTeacher() && request.query.where.teacherId == request.auth.uid;
    }
    match /clubs/{clubId} {
      allow list: if isTeacher() && request.query.where.teacherId == request.auth.uid;
    }
    match /riskFactors/{riskFactorId} {
      allow list: if isTeacher() && request.query.where.teacherId == request.auth.uid;
    }
     match /surveys/{surveyId} {
       allow list: if isTeacher() && request.query.where.teacherId == request.auth.uid;
    }
    match /kazanims/{kazanimId} {
       allow list: if isTeacher() && request.query.where.teacherId == request.auth.uid;
    }
    match /questions/{questionId} {
        allow list: if isTeacher() && request.query.where.teacherId == request.auth.uid;
    }
    
    // --- General Development Rule ---
    // This allows most single-document read/write operations for any signed-in user.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
