
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isTeacher() {
      // It's safe to check existence because of the specific rule on /teachers/{teacherId}
      return request.auth != null && exists(/databases/$(database)/documents/teachers/$(request.auth.uid));
    }
    
    // --- CORE TEACHER RULE ---
    // This rule is CRITICAL. It allows the isTeacher() function to work without recursion.
    match /teachers/{teacherId} {
      allow get: if request.auth != null; // ANY authenticated user can check if a user is a teacher.
      allow write: if isTeacher() && request.auth.uid == teacherId; // Only a teacher can write to their own profile.
    }
    
    // --- PUBLIC/LOGIN RULES ---
    match /publicViews/{viewId} { allow get: if true; }
    match /classCodes/{code} { allow get: if true; }
    
    // --- STUDENT & TEACHER RULES (PER COLLECTION) ---

    // Lessons, Clubs, and Risk Factors
    match /lessons/{lessonId} { 
      allow get, list: if request.auth != null;
      allow write: if isTeacher();
    }
    match /clubs/{clubId} { 
      allow get, list: if request.auth != null;
      allow write: if isTeacher();
    }
    match /riskFactors/{riskFactorId} { 
      allow get, list: if request.auth != null;
      allow write: if isTeacher();
    }
    
    // Classes
    match /classes/{classId} { 
      allow get: if request.auth != null; // Allow students to read their class for login/portal
      allow write: if isTeacher();
      allow list: if isTeacher();
    }
    
    // Students
    match /students/{studentId} {
      allow read: if true; // Student login page needs to list all students in a class.
      allow write: if isTeacher();
      allow update: if (isTeacher()) || (request.auth != null && (
          resource.data.authUid == request.auth.uid ||
          !('authUid' in resource.data) ||
          (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['authUid']))
        ));
    }

    // Info Forms (specific for students, teachers get access below)
    match /infoForms/{formId} {
        allow create: if request.auth != null && request.resource.data.authUid == request.auth.uid;
        allow read, update: if request.auth != null && 
                     get(/databases/$(database)/documents/students/$(formId)).data.authUid == request.auth.uid;
        allow read, write: if isTeacher(); // Teacher override
    }
    
    // Homeworks (Subcollection)
    match /classes/{classId}/homeworks/{homeworkId} {
        allow get, list: if request.auth != null;
        allow write: if isTeacher();
    }
    
    // Submissions (Sub-subcollection)
    match /classes/{classId}/homeworks/{homeworkId}/submissions/{submissionId} {
      allow create: if request.auth != null && request.resource.data.studentAuthUid == request.auth.uid;
      allow read: if request.auth != null && resource.data.studentAuthUid == request.auth.uid;
      allow read, write: if isTeacher(); // Teacher override
    }
    
    // Messages
    match /messages/{messageId} {
      // This single list rule works for both teachers and students, as they both filter by their own UID.
      allow list: if request.auth != null && request.query.where['participants']['array-contains'] == request.auth.uid;
      
      // Allow reading a single message if you are a teacher or part of the conversation.
      allow get: if isTeacher() || (request.auth != null && request.auth.uid in resource.data.participants);
      
      // Allow creating a message if you are a teacher or you are sending it (you are a participant).
      allow create: if isTeacher() || (request.auth != null && request.auth.uid in request.resource.data.participants);

      // Allow updates only by teachers OR by students marking a message as read.
      allow update: if isTeacher() || (request.auth != null && resource.data.receiverId == request.auth.uid && request.resource.data.isRead == true);

      // Only teachers can delete.
      allow delete: if isTeacher();
    }
  }
}
