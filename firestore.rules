
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isTeacher() {
      // Teachers are authenticated users. We can add more specific role checks if needed.
      return isSignedIn();
    }
    
    // COLLECTIONS

    // Anyone can read class info, only teachers can modify it.
    match /classes/{classId} {
      allow read: if true;
      allow write: if isTeacher();

      // Sub-collections inside classes
      match /homeworks/{homeworkId} {
        allow read, write: if isTeacher();
        
        match /submissions/{submissionId} {
            // Students can create their own submission.
            // Teachers can read/update (e.g., for grading).
            allow create: if isSignedIn() && request.resource.data.studentAuthUid == request.auth.uid;
            allow read, update: if isTeacher();
            // A student can read their own submission.
            allow get: if isSignedIn() && resource.data.studentAuthUid == request.auth.uid;
        }
      }
    }

    // Teachers can manage their own students.
    // A student can only read their own data.
    match /students/{studentId} {
      allow read: if isTeacher() || (isSignedIn() && request.auth.uid == resource.data.authUid);
      allow list, create, update, delete: if isTeacher();
    }

    // Teachers can manage their own lessons
    match /lessons/{lessonId} {
      allow read: if true;
      allow write: if isTeacher() && request.resource.data.teacherId == request.auth.uid;
    }

    // Teachers can manage risk factors
    match /riskFactors/{riskFactorId} {
      allow read: if true;
      allow write: if isTeacher();
    }

    // Info forms can only be accessed by the student or a teacher
    match /infoForms/{formId} {
      allow read, write: if isTeacher() || (isSignedIn() && formId == request.auth.uid);
    }
    
    // Messages can only be accessed by participants
    match /messages/{messageId} {
        allow read, write: if isSignedIn() && request.auth.uid in resource.data.participants;
    }

    // Teachers can manage their own profile
    match /teachers/{teacherId} {
      allow read: if true;
      allow write: if isOwner(teacherId);
    }
  }
}
