rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    function isTeacher() {
      // Check if the user has a document in the /teachers collection
      return request.auth != null && exists(/databases/$(database)/documents/teachers/$(request.auth.uid));
    }
    
    function isOwnStudentData(studentId) {
      // Check if the request is for the user's own student document
      // Note: This relies on student documents having an `authUid` field after they log in.
      return request.auth != null && get(/databases/$(database)/documents/students/$(studentId)).data.authUid == request.auth.uid;
    }

    // --- Publicly Readable Data (No auth needed for read) ---
    match /publicViews/{viewId} {
      allow get: if true;
      // Only the teacher who owns the class can write to its public view
      allow write: if isTeacher() && get(/databases/$(database)/documents/classes/$(viewId)).data.teacherId == request.auth.uid;
    }
    match /classCodes/{code} {
      allow get: if true;
      // Any teacher can create a class code
      allow write: if isTeacher();
    }

    // --- Teacher Data ---
    match /teachers/{teacherId} {
      // A teacher can only read or write their own document.
      allow read, write: if request.auth != null && request.auth.uid == teacherId;
    }

    // --- Collections Owned by Teachers ---
    // This rule applies to `classes`, `students`, `lessons`, `riskFactors`, `clubs`
    // All of these collections have a `teacherId` field on their documents.
    match /{collection}/{docId} 
        where collection in ['classes', 'students', 'lessons', 'riskFactors', 'clubs'] {
      // Any teacher can perform a list query on these collections.
      // The actual documents returned will be filtered by the `read` rule below.
      allow list: if isTeacher();

      // For read, update, delete: check the `teacherId` on the *existing* document.
      allow read, update, delete: if isTeacher() && resource.data.teacherId == request.auth.uid;
      
      // For create: check the `teacherId` on the *incoming* document.
      allow create: if isTeacher() && request.resource.data.teacherId == request.auth.uid;
    }

    // --- Student-Specific Overrides ---
    match /students/{studentId} {
        // Students can read their own document after they have logged in and their `authUid` is set.
        allow read: if isOwnStudentData(studentId) || (isTeacher() && resource.data.teacherId == request.auth.uid);
        // Students can update their own document (e.g. for preferences, info forms).
        allow update: if isOwnStudentData(studentId) || (isTeacher() && resource.data.teacherId == request.auth.uid);
    }
    
    // --- Homework Subcollection ---
    match /classes/{classId}/homeworks/{homeworkId} {
      // The owner of the class can manage homework.
      allow read, list, write, delete: if isTeacher() && get(/databases/$(database)/documents/classes/$(classId)).data.teacherId == request.auth.uid;
    }

    // --- Submissions Collection Group (for student queries) ---
    match /{path=**}/submissions/{submissionId} {
      // A student can create and read their own submissions across any homework.
      allow create: if request.auth != null && request.resource.data.studentAuthUid == request.auth.uid;
      allow read, list: if request.auth != null && resource.data.studentAuthUid == request.auth.uid;
      
      // Teachers can update submissions (e.g., for grading) in their own classes.
      allow update: if isTeacher();
    }

    // --- Student Info Forms ---
    match /infoForms/{studentId} {
      // A student can write to their own info form.
      allow write: if isOwnStudentData(studentId);
      // The student and their teacher can read the info form.
      allow read: if isOwnStudentData(studentId) || (isTeacher() && get(/databases/$(database)/documents/students/$(studentId)).data.teacherId == request.auth.uid);
    }
    
    // --- Messaging ---
    match /messages/{messageId} {
      // Participants can read messages in the chat.
      allow read: if request.auth != null && request.auth.uid in resource.data.participants;
      // Users can list chats they are a part of.
      allow list: if request.auth != null && request.query.where['participants']['array-contains'] == request.auth.uid;
      // Only the sender can create the message.
      allow create: if request.auth != null && request.resource.data.senderId == request.auth.uid;
      // Only the receiver can update a message (e.g., to mark as read).
      allow update: if request.auth != null && resource.data.receiverId == request.auth.uid;
    }
  }
}
