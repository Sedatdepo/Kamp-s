rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if a user is a registered teacher
    function isTeacher(userId) {
      return exists(/databases/$(database)/documents/teachers/$(userId));
    }

    // Helper function to check if the user is the owner of a document
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    // PUBLIC and semi-public collections
    match /publicViews/{viewId} {
      allow get: if true;
      allow write: if request.auth != null &&
                      isTeacher(request.auth.uid) &&
                      get(/databases/$(database)/documents/classes/$(viewId)).data.teacherId == request.auth.uid;
    }
    
    match /classCodes/{code} {
      allow get: if true;
      allow write: if request.auth != null && isTeacher(request.auth.uid);
    }

    // TEACHER-OWNED collections
    match /teachers/{teacherId} {
        allow read: if request.auth != null;
        allow write: if isOwner(teacherId);
    }

    // CLASS collection and subcollections
    match /classes/{classId} {
      // Only the owner teacher can write, any auth'd user can read
      allow read: if true;
      allow write: if request.auth != null && isTeacher(request.auth.uid) && request.resource.data.teacherId == request.auth.uid;
      
      // HOMEWORKS subcollection
      match /homeworks/{homeworkId} {
        // Teacher can do anything
        allow read, write: if request.auth != null &&
                             isTeacher(request.auth.uid) &&
                             get(/databases/$(database)/documents/classes/$(classId)).data.teacherId == request.auth.uid;
        
        // SUBMISSIONS sub-subcollection
        match /submissions/{submissionId} {
          // Student can create their own submission
          allow create: if request.auth != null;
          
          // Teacher can read/update/delete all submissions in their class
          allow read, update, delete: if request.auth != null &&
                                          isTeacher(request.auth.uid) &&
                                          get(/databases/$(database)/documents/classes/$(classId)).data.teacherId == request.auth.uid;
          
          // Student can read their own submission
          allow get: if request.auth != null && resource.data.studentId == request.auth.uid;
        }
      }
    }

    // STUDENTS collection
    match /students/{studentId} {
      // Teacher can read/write all their students
      allow read, write: if request.auth != null && isTeacher(request.auth.uid);
      // Student can read their own data, and update certain fields (like preferences)
      allow get: if request.auth != null && resource.data.authUid == request.auth.uid;
      allow update: if request.auth != null && resource.data.authUid == request.auth.uid;
    }

    // MESSAGES collection
    match /messages/{messageId} {
      allow get, list: if request.auth != null && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null && request.resource.data.senderId == request.auth.uid;
      allow update: if request.auth != null && resource.data.receiverId == request.auth.uid && request.resource.data.keys().hasOnly(['isRead']);
    }

    // OTHER top-level collections for teachers
    match /lessons/{lessonId} { allow read, write: if request.auth != null && isTeacher(request.auth.uid); }
    match /riskFactors/{factorId} { allow read, write: if request.auth != null && isTeacher(request.auth.uid); }
    match /clubs/{clubId} { allow read, write: if request.auth != null && isTeacher(request.auth.uid); }
    match /teacherData/{teacherId} { allow read, write: if isOwner(teacherId); }
    match /infoForms/{formId} { allow read, write: if request.auth != null; }
  }
}
