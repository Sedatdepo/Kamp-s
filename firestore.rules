rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      // DİKKAT: Bu kural geliştirme için basitleştirilmiştir.
      // Herhangi bir kullanıcının tüm verilere okuma ve yazma erişimi vardır.
      // Prodüksiyon ortamında kullanılmamalıdır.
      allow read, write: if true;
    }
  }
}
