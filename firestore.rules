
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Function ---
    function isTeacher() {
      // This function relies on a rule that allows reading from the /teachers collection.
      return request.auth != null && exists(/databases/$(database)/documents/teachers/$(request.auth.uid));
    }
    
    // Rule to allow the isTeacher() check to work without recursion.
    // This is evaluated before the wildcard rule because it's more specific.
    match /teachers/{teacherId} {
      allow get: if request.auth != null;
    }

    // RULE 1: Teachers have god-mode.
    // This single rule grants full access to any teacher. 'read' includes 'get' and 'list'.
    // For non-teachers, this rule denies access, and they must rely on the more specific rules below.
    match /{document=**} {
      allow read, write: if isTeacher();
    }
    
    // --- NON-TEACHER (Student & Public) ACCESS RULES ---
    
    // Publicly viewable pages.
    match /publicViews/{viewId} { allow get: if true; }
    match /classCodes/{code} { allow get: if true; }

    // Student login process.
    match /students/{studentId} {
        allow read: if true; 
        allow update: if request.auth != null; // For anonymous login to claim their doc
    }
    
    // Students reading data for selection forms and portal functionality.
    // 'read' allows both 'get' (single doc) and 'list' (collection query)
    match /classes/{classId} { allow get: if request.auth != null; }
    match /lessons/{lessonId} { allow read: if request.auth != null; }
    match /clubs/{clubId} { allow read: if request.auth != null; }
    match /riskFactors/{riskFactorId} { allow read: if request.auth != null; }
    match /classes/{classId}/homeworks/{homeworkId} {
      allow get: if request.auth != null;
    }
    
    // Students can manage their own submissions.
    match /classes/{classId}/homeworks/{homeworkId}/submissions/{submissionId} {
      allow create: if request.auth != null && request.resource.data.studentAuthUid == request.auth.uid;
      allow read: if request.auth != null && resource.data.studentAuthUid == request.auth.uid;
    }
    
    // Students can manage their own info form.
    match /infoForms/{studentId} {
      allow read, write: if request.auth != null;
    }
    
    // Students can send and receive messages.
    match /messages/{messageId} {
      allow read, create, update: if request.auth != null && request.auth.uid in resource.data.participants;
    }
  }
}
