rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- YARDIMCI FONKSİYONLAR ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isTeacher() {
      // Bu fonksiyon, bir kullanıcının öğretmen rolüne sahip olup olmadığını kontrol eder.
      // Sadece tekil belge okuma/yazma (get, update, create) işlemlerinde güvenle kullanılabilir.
      // Listeleme (list) sorgularında kullanılmamalıdır.
      return isSignedIn() && exists(/databases/$(database)/documents/teachers/$(request.auth.uid));
    }

    // --- GENEL GİRİŞ SORGULARI (KİMLİK DOĞRULANMAMIŞ) ---
    // Öğrencinin, giriş yapabilmesi için sınıf ve öğrenci bilgilerini arayabilmesi gerekir.
    // Bu kurallar, henüz giriş yapmamış bir kullanıcının bu iki koleksiyonda SADECE listeleme yapmasına izin verir.
    // DİKKAT: Bu kurallar olmadan öğrenci girişi çalışmaz.
    match /classes/{classId} {
        allow list: if true; // Öğrencinin sınıf kodunu sorgulamasına izin ver
    }
    match /students/{studentId} {
        // Bu kural hem öğrencinin kendi numarasını sorgulamasına hem de öğretmenin
        // öğrenci listesini çekmesine olanak tanır. Daha detaylı kurallar aşağıdadır.
        allow list: if true;
    }

    // --- ÖĞRETMEN KOLEKSİYONU ---
    match /teachers/{teacherId} {
      allow read: if isSignedIn();
      allow write: if isOwner(teacherId);
    }

    // --- SINIFLAR VE ALT KOLEKSİYONLARI ---
    match /classes/{classId} {
      // ÖĞRETMEN YETKİLERİ
      // Bir öğretmen, YALNIZCA kendi 'teacherId'sine sahip sınıfları listeleyebilir.
      // Bu kural, `where('teacherId', '==', request.auth.uid)` sorgusu ile çalışır.
      allow list: if isSignedIn() && request.query.where.teacherId == request.auth.uid;
      // Bir öğretmen, kendi sınıfına ait belgeleri okuyabilir (get), silebilir ve güncelleyebilir.
      allow get, update, delete: if isSignedIn() && get(/databases/$(database)/documents/classes/$(classId)).data.teacherId == request.auth.uid;
      // Bir öğretmen yeni sınıf oluşturabilir.
      allow create: if isTeacher() && request.resource.data.teacherId == request.auth.uid;

      // SINIFIN ALTINDAKİ ÖĞRENCİLER
      match /students/{studentId} {
        // Öğretmen kendi sınıfındaki öğrencileri okuyabilir, yazabilir (ekleme, silme, güncelleme).
        allow read, write: if isSignedIn() && get(/databases/$(database)/documents/classes/$(classId)).data.teacherId == request.auth.uid;
      }
      
      // SINIFIN ALTINDAKİ ÖDEVLER
      match /homeworks/{homeworkId} {
        // Öğretmen kendi sınıfındaki ödevleri yönetebilir.
        allow read, write: if isSignedIn() && get(/databases/$(database)/documents/classes/$(classId)).data.teacherId == request.auth.uid;
        // Öğrenci kendi sınıfındaki ödevleri okuyabilir.
        allow get, list: if isSignedIn() && get(/databases/$(database)/documents/students/$(request.auth.uid)).data.classId == classId;
        
        match /submissions/{submissionId} {
            // Öğretmen teslimleri okuyabilir/yazabilir.
            allow read, write: if isSignedIn() && get(/databases/$(database)/documents/classes/$(classId)).data.teacherId == request.auth.uid;
            // Öğrenci sadece kendi teslimini oluşturabilir.
            allow create: if isSignedIn() && request.resource.data.studentId == request.auth.uid;
            // Öğrenci sadece kendi teslimini okuyabilir/güncelleyebilir.
            allow get, update: if isSignedIn() && resource.data.studentId == request.auth.uid;
        }
      }
    }

    // --- ÖĞRENCİYE ÖZEL BELGELER (ANA KOLEKSİYONLAR) ---
    match /students/{studentId} {
      // Bir öğrenci sadece kendi profilini okuyabilir ve güncelleyebilir.
      allow get, update: if isOwner(studentId);
    }
    
    match /infoForms/{formId} {
      // Öğrenci sadece kendi bilgi formunu oluşturabilir, okuyabilir ve güncelleyebilir (formId = studentId).
      allow read, create, update: if isOwner(formId);
      // Öğretmen, raporlama için tüm formları okuyabilir.
      allow list: if isTeacher();
    }
    
    // --- DİĞER GENEL KOLEKSİYONLAR ---
    match /riskFactors/{riskFactorId} {
      allow read: if isSignedIn(); // Tüm giriş yapmış kullanıcılar okuyabilir.
      allow write: if isTeacher();   // Sadece öğretmenler yazabilir.
    }

    match /lessons/{lessonId} {
      allow read: if isSignedIn();
      allow write: if isTeacher();
    }
    
    match /messages/{messageId} {
      // Sadece sohbete dahil olanlar mesajları okuyabilir/yazabilir.
      allow read, write: if isSignedIn() && request.auth.uid in resource.data.participants;
    }
    
    match /surveys/{surveyId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isTeacher();
    }
    
    match /surveyResponses/{responseId} {
      allow create: if isSignedIn(); // Öğrenciler yanıt oluşturabilir.
      allow read, list: if isTeacher(); // Öğretmenler tüm yanıtları okuyabilir.
    }
    
    match /kazanims/{kazanimId} {
      allow read: if isSignedIn();
      allow write: if isTeacher();
    }

    match /questions/{questionId} {
      allow read: if isSignedIn();
      allow write: if isTeacher();
    }
  }
}
