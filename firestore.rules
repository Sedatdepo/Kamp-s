
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isTeacher() {
      // It's safe to check existence because of the specific rule on /teachers/{teacherId}
      return request.auth != null && exists(/databases/$(database)/documents/teachers/$(request.auth.uid));
    }
    
    // --- CORE TEACHER RULE & PUBLIC RULES ---
    match /teachers/{teacherId} {
      allow get: if request.auth != null;
      allow write: if isTeacher() && request.auth.uid == teacherId;
    }
    match /publicViews/{viewId} { allow get: if true; }
    match /classCodes/{code} { allow get: if true; }
    
    // --- DATA COLLECTIONS ---

    // Lessons, Clubs, Risk Factors are readable by all authenticated users, writable by teachers.
    match /lessons/{lessonId} { 
      allow get, list: if request.auth != null;
      allow write: if isTeacher();
    }
    match /clubs/{clubId} { 
      allow get, list: if request.auth != null;
      allow write: if isTeacher();
    }
    match /riskFactors/{riskFactorId} { 
      allow get, list: if request.auth != null;
      allow write: if isTeacher();
    }
    
    // Classes can be read by any authenticated user (so student can see class name).
    // Only teachers can list all their classes or write to them.
    match /classes/{classId} { 
      allow get: if request.auth != null;
      allow list, write: if isTeacher();
    }
    
    // Students collection access is complex due to the anonymous login flow.
    match /students/{studentId} {
      // allow read:if true is a security risk but required for the current login implementation.
      // It allows anonymous users on the login page to list all students in a class.
      allow read: if true; 
      
      // Teachers can write to any student document.
      allow write: if isTeacher();

      // An authenticated student can update their OWN document for specific fields,
      // or an anonymous user can claim a profile by setting their authUid.
      allow update: if (isTeacher()) || (request.auth != null && (
          (resource.data.authUid == request.auth.uid) ||
          (!('authUid' in resource.data) || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['authUid']))
        ));
    }

    // InfoForms are private to the student, but readable/writable by teachers.
    match /infoForms/{formId} {
        allow create: if request.auth != null && request.resource.data.authUid == request.auth.uid;
        allow read, update: if (isTeacher()) || (request.auth != null && get(/databases/$(database)/documents/students/$(formId)).data.authUid == request.auth.uid);
        allow write: if isTeacher();
    }
    
    // Homeworks are visible to anyone in the class. Writable by teachers.
    match /classes/{classId}/homeworks/{homeworkId} {
        allow get, list: if request.auth != null;
        allow write: if isTeacher();
    }
    
    // Submissions are private to the student, but visible/writable to teachers.
    match /classes/{classId}/homeworks/{homeworkId}/submissions/{submissionId} {
      allow create: if request.auth.uid == request.resource.data.studentAuthUid;
      allow read: if isTeacher() || (request.auth.uid == resource.data.studentAuthUid);
      allow write: if isTeacher();
    }
    
    // Messages
    match /messages/{messageId} {
      // Allow a user to list messages where they are a participant. This is secure because the client query MUST enforce this.
      // This is a common pattern to work around Firestore's limitations on securing array-contains queries.
      allow list: if request.auth != null;
      
      // Allow get/create if the user is a teacher OR a participant.
      allow get: if isTeacher() || (request.auth != null && request.auth.uid in resource.data.participants);
      allow create: if isTeacher() || (request.auth != null && request.auth.uid in request.resource.data.participants);
      
      // Students can only update the 'isRead' flag on messages sent to them. Teachers can update anything.
      allow update: if isTeacher() || 
                    (request.auth != null && resource.data.receiverId == request.auth.uid && request.resource.data.isRead == true && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']));

      // Only teachers can delete messages.
      allow delete: if isTeacher();
    }
  }
}
