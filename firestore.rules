
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    function isTeacher() {
      return request.auth != null && exists(/databases/$(database)/documents/teachers/$(request.auth.uid));
    }
    
    // --- Core Authentication Rules ---
    // This rule is critical for the isTeacher() function to work securely.
    match /teachers/{teacherId} {
      allow get: if request.auth != null; // Any authenticated user can check if a user is a teacher.
      allow write: if isTeacher() && request.auth.uid == teacherId; // Only a teacher can write to their own profile.
    }

    // --- Publicly Readable Data ---
    match /publicViews/{viewId} { allow get: if true; }
    match /classCodes/{code} { allow get: if true; }

    // --- Teacher-Managed Global Data ---
    // Lessons, Clubs, and Risk Factors are readable by any authenticated user, but only writable by teachers.
    match /lessons/{lessonId} { 
      allow get, list: if request.auth != null;
      allow write: if isTeacher();
    }
    match /clubs/{clubId} { 
      allow get, list: if request.auth != null;
      allow write: if isTeacher();
    }
    match /riskFactors/{riskFactorId} { 
      allow get, list: if request.auth != null;
      allow write: if isTeacher();
    }
    
    // --- Class-Specific Data ---
    match /classes/{classId} {
      // Any authenticated user (student or teacher) can get a class's details.
      allow get: if request.auth != null;
      // Only teachers can list all classes or write to a class document.
      allow list, write: if isTeacher();
    }
    
    // --- Student Data ---
    // This is the most complex rule due to the anonymous login/claim flow.
    match /students/{studentId} {
      // SECURITY RISK: This is intentionally open to allow the initial anonymous login
      // where a student needs to find their profile from a list before they are authenticated as "that student".
      // This should be replaced with a more secure Cloud Function-based lookup in a real production app.
      allow read: if true; 
      
      // Teachers have full write permissions on any student.
      // An authenticated student can only update their OWN document.
      // An anonymous user can only claim a profile by setting their authUid.
      allow update: if isTeacher() || 
                    (request.auth != null && 
                      (
                        // Case 1: Authenticated student updates their own document.
                        (resource.data.authUid == request.auth.uid) ||
                        // Case 2: Anonymous user claims a profile by setting authUid for the first time.
                        (!('authUid' in resource.data) || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['authUid']))
                      )
                    );
      
      // Only teachers can create or delete students.
      allow create, delete: if isTeacher();
    }

    // --- Student-Owned Sub-Collections & Data ---
    
    // InfoForms are private to the student but can be managed by teachers.
    match /infoForms/{studentId} {
        allow create: if request.auth != null && request.resource.data.authUid == request.auth.uid;
        allow read, update: if (isTeacher()) || (request.auth != null && get(/databases/$(database)/documents/students/$(studentId)).data.authUid == request.auth.uid);
        allow delete: if isTeacher();
    }
    
    // Homeworks are visible to anyone in the class. Writable only by teachers.
    match /classes/{classId}/homeworks/{homeworkId} {
        allow get, list: if request.auth != null;
        allow write: if isTeacher();
    }
    
    // Submissions are private to the student, but visible/writable to teachers.
    match /classes/{classId}/homeworks/{homeworkId}/submissions/{submissionId} {
      allow create: if request.auth.uid == request.resource.data.studentAuthUid;
      allow read: if isTeacher() || (request.auth.uid == resource.data.studentAuthUid);
      allow write: if isTeacher();
    }
    
    // --- Messaging Rules ---
    match /messages/{messageId} {
      // A user can list messages ONLY if their UID is in the 'participants' array.
      // This is a secure and common pattern for group chats.
      allow list: if request.auth != null && request.query.where['participants']['array-contains'] == request.auth.uid;
      
      // A user can get a message if they are a participant. Teachers can get any message.
      allow get: if isTeacher() || (request.auth != null && request.auth.uid in resource.data.participants);
      
      // A user can create a message if they are including themselves in the participants list.
      allow create: if request.auth != null && request.auth.uid in request.resource.data.participants;
      
      // Students can only update the 'isRead' flag on messages sent to them. Teachers can update anything.
      allow update: if isTeacher() || 
                    (request.auth != null && resource.data.receiverId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']));

      // Only teachers can delete messages.
      allow delete: if isTeacher();
    }
  }
}
