
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isTeacher() {
      return exists(/databases/$(database)/documents/roles_teacher/$(request.auth.uid));
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isSignedIn() {
      return request.auth != null;
    }
    
    match /classes/{classId} {
      allow read, write: if isTeacher();
      
      // Öğrenciler sadece kendi sınıflarının bilgilerini okuyabilir.
      allow get: if isSignedIn();

      match /homeworks/{homeworkId} {
        allow read, write: if isTeacher();
        allow read: if isSignedIn();

        match /submissions/{submissionId} {
          allow read, write: if isTeacher();
          allow list: if isTeacher();
          allow create: if isOwner(request.resource.data.studentId);
        }
      }
    }
    
    match /students/{studentId} {
      allow get: if isOwner(studentId) || isTeacher();
      allow list, create, delete: if isTeacher();
      // Öğrencinin kendi risklerini vs. güncellemesine izin ver
      allow update: if isOwner(studentId) || isTeacher();
    }

    match /teachers/{teacherId} {
        allow read: if isSignedIn();
        allow write: if isOwner(teacherId);
    }

    match /infoForms/{formId} {
      allow read, write: if isTeacher();
      allow create, update: if isOwner(formId);
      allow get: if isOwner(formId);
    }
    
    match /riskFactors/{factorId} {
      allow read, write: if isTeacher();
    }

    match /lessons/{lessonId} {
      allow read: if isSignedIn();
      allow write: if isTeacher();
    }
    
    match /messages/{messageId} {
      allow read, write: if request.auth.uid in resource.data.participants;
      allow list: if isSignedIn() && request.query.filters[0][2] == request.auth.uid;
    }
    
    match /roles_teacher/{uid} {
        allow read, write: if false;
    }

    match /studentCredentials/{uid} {
        allow read, write: if false; // Should only be accessible by backend/admin
    }

     match /surveys/{surveyId} {
        allow get, list: if isSignedIn();
        allow create, update, delete: if isTeacher();
    }
    match /surveyResponses/{responseId} {
        allow create: if isSignedIn();
        allow read, list: if isTeacher();
        allow update, delete: if isTeacher();
    }
  }
}
