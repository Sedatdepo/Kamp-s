
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isTeacher() {
      return exists(/databases/$(database)/documents/teachers/$(request.auth.uid));
    }
    
    function isDataOwner(teacherId) {
      return isTeacher() && request.auth.uid == teacherId;
    }

    // --- Teacher Profiles ---
    match /teachers/{teacherId} {
      allow read: if isSignedIn();
      allow write: if isOwner(teacherId);
    }

    // --- Classes and Subcollections ---
    match /classes/{classId} {
      // Bir öğretmenin yalnızca 'teacherId' alanı kendi kimliğiyle eşleşen sınıfları listelemesine izin ver.
      allow list: if isTeacher() && request.query.where[0][0] == 'teacherId' && request.query.where[0][2] == request.auth.uid;
      
      // Bir öğretmen, yalnızca sahibi olduğu sınıfı tekil olarak okuyabilir, güncelleyebilir veya silebilir.
      allow get, update, delete: if isDataOwner(get(/databases/$(database)/documents/classes/$(classId)).data.teacherId);
      
      // Bir öğretmen, 'teacherId'si kendisine ait olan bir sınıf oluşturabilir.
      allow create: if isDataOwner(request.resource.data.teacherId);
      
      // --- Students within a class ---
      match /students/{studentId} {
        // Bir öğretmen, kendi sınıfındaki öğrencilere tam erişime sahiptir.
        // Bu kural, üstteki /classes/{classId} kuralındaki `get` iznine dayanır.
        allow read, write: if isDataOwner(get(/databases/$(database)/documents/classes/$(classId)).data.teacherId);
      }
      
      // --- Other subcollections (lessons, homeworks, etc.) ---
      match /{allChildren=**} {
         // Bir öğretmen, kendi sınıfının altındaki tüm diğer alt koleksiyonlara tam erişime sahiptir.
         allow read, write: if isDataOwner(get(/databases/$(database)/documents/classes/$(classId)).data.teacherId);
      }
    }
    
    // --- Top-level collections owned by teachers ---
    match /lessons/{lessonId} {
      // Bir öğretmen, yalnızca kendi oluşturduğu derslere erişebilir.
      allow read, write: if isDataOwner(resource.data.teacherId);
    }
    
    match /riskFactors/{riskFactorId} {
       // Bir öğretmen, yalnızca kendi oluşturduğu risk faktörlerine erişebilir.
       allow read, write: if isDataOwner(resource.data.teacherId);
    }
    
     match /questions/{questionId} {
       // Bir öğretmen, yalnızca kendi oluşturduğu sorulara erişebilir.
       allow read, write: if isDataOwner(resource.data.teacherId);
    }
    
     match /kazanims/{kazanimId} {
       // Bir öğretmen, yalnızca kendi oluşturduğu kazanımlara erişebilir.
       allow read, write: if isDataOwner(resource.data.teacherId);
    }

    // --- Publicly readable collections ---
    match /classCodes/{code} {
      allow get: if isSignedIn();
    }
  }
}
